# Router bind
ROUTER_HOST=0.0.0.0
ROUTER_PORT=9000

# Public hostname (what jobs should register as)
PUBLIC_HOSTNAME=127.0.0.1


# Auth
AUTH_PASSWORD=changeme
# AUTH_SECRET_KEY=  # Optional: set for stable sessions across restarts
# AUTH_SESSION_MAX_AGE_SECONDS=86400  # 24h default


# DB (Local file by default for ease of use)
DATABASE_URL=sqlite:///./router.db

# Slurm Settings (Leave empty to detect defaults)
SLURM_PARTITION=
SLURM_ACCOUNT=
SLURM_QOS=
SLURM_NODELIST=
SLURM_CPUS_PER_TASK=16

# Slurm email notifications (optional — leave SLURM_MAIL_USER empty to disable)
# SLURM_MAIL_USER=your-email@example.com
# SLURM_MAIL_TYPE=FAIL,END,TIME_LIMIT

# Logs
VLLM_LOG_DIR=./logs

VLLM_API_KEY=secret

# Read-only API key for external schedule viewers (e.g., dashboards, status pages).
# Clients pass this via Authorization: Bearer <key> or ?token=<key>
# Leave empty to disable the public schedule API entirely.
SCHEDULE_API_KEY=

# vLLM job health waiting and retry behavior (fail fast + one retry)
VLLM_HEALTH_TIMEOUT_SECONDS=800
VLLM_MAX_RETRIES=1
VLLM_RETRY_DELAY_SECONDS=10

# Templates
SBATCH_TEMPLATE_PATH=./templates/vllm_job.sh

TOTAL_GPUS=8

# Logic
ALLOW_ON_DEMAND_START=false
