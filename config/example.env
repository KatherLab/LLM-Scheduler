# Router bind
ROUTER_HOST=0.0.0.0
ROUTER_PORT=9000

# Public hostname (what jobs should register as; for single node can be same as node DNS name)
PUBLIC_HOSTNAME=127.0.0.1

# DB (SQLite by default)
DATABASE_URL=sqlite:////var/lib/vllm-router/router.db

# Slurm
SLURM_PARTITION=
SLURM_ACCOUNT=
SLURM_QOS=
SLURM_NODELIST=
SLURM_CPUS_PER_TASK=32

# Port pool for vLLM jobs (internal only)
PORT_MIN=8010
PORT_MAX=8099

# Logs for vLLM jobs
VLLM_LOG_DIR=/var/log/vllm

# Templates
SBATCH_TEMPLATE_PATH=/opt/vllm-swapper-router/templates/vllm_job.sh

# Optional: default model to (re)launch when idle
DEFAULT_MODEL=
DEFAULT_MODEL_GPUS=
DEFAULT_MODEL_TP=

# Optional: allow on-demand start from proxy when no endpoint is READY
ALLOW_ON_DEMAND_START=false
ON_DEMAND_MAX_WAIT_SECONDS=30
